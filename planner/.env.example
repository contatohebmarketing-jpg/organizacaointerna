# Local (desenvolvimento): banco SQLite em arquivo
TURSO_DATABASE_URL="file:./prisma/dev.db"
# TURSO_AUTH_TOKEN não é necessário no modo arquivo local

# Produção (Vercel) com Turso — preencha na Vercel:
# TURSO_DATABASE_URL="libsql://SEU-BANCO.turso.io"
# TURSO_AUTH_TOKEN="seu-token-aqui"

# Usado apenas pela CLI do Prisma (migrate/db push) em desenvolvimento
DATABASE_URL="file:./dev.db"
