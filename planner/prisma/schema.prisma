generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("blue")
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
  tasks     Task[]   @relation("ProjectTasks")
}

model Task {
  id          String    @id @default(cuid())
  title       String
  notes       String?
  status      String    @default("todo") // todo | doing | done
  priority    String    @default("media") // alta | media | baixa
  dueDate     DateTime? // data de início (dia, meio-dia UTC)
  startMin    Int? // hora de início (min desde a meia-noite); null = dia todo
  endDate     DateTime? // data de término (dia); null = mesmo dia que dueDate
  endMin      Int? // hora de término (min); null = sem hora de término
  repeat      String    @default("none") // none | daily | weekdays | weekly | monthly
  durationMin Int       @default(60) // fallback p/ bloco quando não há endMin
  pushCount   Int       @default(0)
  order       Int       @default(0)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  projects    Project[] @relation("ProjectTasks")
}
