generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("blue") // chave da paleta (ver src/lib/colors.ts)
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
  tasks     Task[]   @relation("ProjectTasks")
}

model Task {
  id          String    @id @default(cuid())
  title       String
  notes       String? // "do que se trata" — lembretes/pontos importantes
  status      String    @default("todo") // todo | doing | done
  priority    String    @default("media") // alta | media | baixa
  dueDate     DateTime? // data (meia-noite local)
  startMin    Int? // minutos desde a meia-noite; null = sem horário
  durationMin Int       @default(60) // tempo médio de duração
  pushCount   Int       @default(0) // quantas vezes foi adiada para frente
  order       Int       @default(0)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  projects    Project[] @relation("ProjectTasks")
}
